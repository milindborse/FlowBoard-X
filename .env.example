# Copy to .env and fill in for docker-compose, or export these in your shell
# before running the backend with `mvn spring-boot:run`.

JWT_SECRET=change-this-secret-in-production-it-must-be-at-least-256-bits-long

# Optional: only needed if you want the Email node to actually send mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
